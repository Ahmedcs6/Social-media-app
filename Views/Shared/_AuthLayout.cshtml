@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);

    var fullName = user.FullName;
    var email = user.Email;
    var imageUrl = string.IsNullOrEmpty(user?.ImageUrl)
        ? "/images/default-profile-img.jpg"
        : $"/images/user/{user.ImageUrl}";
		var userName = user.UserName;
		ViewData["Title"] = "Feed";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ConnectHub - @ViewData["Title"]</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg-base:        #0d1117;
      --bg-surface:     #161b22;
      --bg-elevated:    #1c2330;
      --bg-hover:       #21303f;
      --cyan:           #0fd4c8;
      --cyan-dim:       #0aada3;
      --cyan-glow:      rgba(15, 212, 200, 0.18);
      --text-primary:   #e6edf3;
      --text-secondary: #7d8ea1;
      --text-muted:     #4a5568;
      --border:         rgba(255, 255, 255, 0.08);
      --border-strong:  rgba(255, 255, 255, 0.14);
      --danger:         #f87171;
      --danger-bg:      rgba(248, 113, 113, 0.1);
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: var(--bg-base);
      color: var(--text-primary);
    }

    /* ── Navbar ── */
    .navbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      height: 48px;          /* was 62px */
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      position: relative;
      z-index: 10;
    }

    /* ── Logo ── */
    .logo {
      font-size: 20px;       /* was 20px */
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--text-primary);
      text-decoration: none;
      flex-shrink: 0;
    }

    .logo span { color: var(--cyan); }

    /* ── Nav links group ── */
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
    }

    /* ── Icon buttons ── */
    .nav-icon {
      position: relative;
      width: 34px;           /* was 42px */
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
      cursor: pointer;
    }

    .nav-icon:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .nav-icon.active {
      background: var(--cyan-glow);
      color: var(--cyan);
    }

    .nav-icon i { font-size: 15px; } /* was 18px */

    /* ── Notification badge ── */
    .nav-icon .badge {
      position: absolute;
      top: 4px;
      right: 4px;
      min-width: 14px;
      height: 14px;
      border-radius: 7px;
      background: var(--cyan);
      color: #0d1117;
      font-size: 9px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 3px;
      line-height: 1;
      border: 2px solid var(--bg-surface);
    }

    /* ── Avatar button ── */
    .avatar-btn {
      width: 30px;           /* was 36px */
      height: 30px;
      border-radius: 50%;
      background: var(--cyan-dim);
      border: 2px solid var(--cyan);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0d1117;
      font-size: 11px;       /* was 12px */
      font-weight: 700;
      font-family: inherit;
      margin-left: 6px;
      transition: box-shadow 0.2s, transform 0.15s;
      outline: none;
      flex-shrink: 0;
    }

    .avatar-btn:hover {
      box-shadow: 0 0 0 3px var(--cyan-glow);
      transform: scale(1.05);
    }

    .avatar-btn:focus-visible {
      box-shadow: 0 0 0 3px var(--cyan);
    }

    /* ── Dropdown ── */
    .dropdown {
      position: absolute;
      top: calc(100% + 6px);
      right: 16px;
      width: 210px;
      background: var(--bg-elevated);
      border: 1px solid var(--border-strong);
      border-radius: 12px;
      padding: 6px;
      z-index: 300;
      opacity: 0;
      transform: translateY(-6px) scale(0.97);
      pointer-events: none;
      transition: opacity 0.18s ease, transform 0.18s ease;
      box-shadow: 0 16px 40px rgba(0,0,0,0.5), 0 0 0 1px var(--border);
    }

    .dropdown.open {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: all;
    }

    /* ── Dropdown header ── */
    .dropdown-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px 10px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
    }

    .dropdown-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--cyan-dim);
      border: 2px solid var(--cyan);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0d1117;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0;
    }

    .dropdown-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .dropdown-email {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 1px;
    }

    /* ── Dropdown items ── */
    .dropdown-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      border-radius: 7px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-primary);
      cursor: pointer;
      text-decoration: none;
      border: none;
      background: none;
      width: 100%;
      font-family: inherit;
      transition: background 0.12s, color 0.12s;
      text-align: left;
    }

    .dropdown-item:hover { background: var(--bg-hover); color: var(--cyan); }
    .dropdown-item:hover i { color: var(--cyan); }

    .dropdown-item i {
      font-size: 14px;
      color: var(--text-secondary);
      width: 16px;
      text-align: center;
      transition: color 0.12s;
      flex-shrink: 0;
    }

    /* ── Logout ── */
    .dropdown-item.logout {
      color: var(--danger);
      margin-top: 2px;
      border-top: 1px solid var(--border);
      padding-top: 9px;
      border-radius: 0 0 7px 7px;
    }

    .dropdown-item.logout i { color: var(--danger); }
    .dropdown-item.logout:hover { background: var(--danger-bg); color: var(--danger); }
    .dropdown-item.logout:hover i { color: var(--danger); }

    /* ── Page body ── */
    .page-body {
      display: flex;
      align-items: center;
      justify-content: center;
      height: calc(100vh - 48px);
      color: var(--text-muted);
      font-size: 14px;
    }
  </style>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>

  <nav class="navbar">

    <a href="/Home" class="logo">Connect<span>Hub</span></a>

    <div class="nav-links">

      <a href="/Home" class="nav-icon active" title="Home">
        <i class="fa-solid fa-house"></i>
      </a>

      <a href="/Search" class="nav-icon" title="Search">
        <i class="fa-solid fa-magnifying-glass"></i>
      </a>

      <a href="/Notifications" class="nav-icon" title="Notifications">
        <i class="fa-solid fa-bell"></i>
        <span class="badge">3</span>
      </a>

      <button
        class="avatar-btn"
        id="avatarBtn"
        aria-label="Open profile menu"
        aria-haspopup="true"
        aria-expanded="false"
      >
        <img src="@imageUrl"
         alt="@fullName"
         style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
      </button>

    </div>

    <!-- Profile dropdown (inside navbar so position:absolute works) -->
    <div class="dropdown" id="dropdown" role="menu" aria-label="Profile menu">

      <div class="dropdown-header">
        <div class="dropdown-avatar">
				<img src="@imageUrl"
         alt="@fullName"
         style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
				</div>
        <div>
          <div class="dropdown-name">@fullName</div>
          <div class="dropdown-email">@@@userName</div>
        </div>
      </div>

      <a href="Profile/@userName" class="dropdown-item" role="menuitem">
        <i class="fa-solid fa-user"></i> View profile
      </a>

      <a href="/Settings" class="dropdown-item" role="menuitem">
        <i class="fa-solid fa-gear"></i> Settings
      </a>

      <a href="/Saved" class="dropdown-item" role="menuitem">
        <i class="fa-solid fa-bookmark"></i> Saved posts
      </a>

      <form action="/Account/Logout" method="post" style="margin:0;">
				@Html.AntiForgeryToken()
        <button type="submit" class="dropdown-item logout" role="menuitem">
          <i class="fa-solid fa-right-from-bracket"></i> Log out
        </button>
      </form>

    </div>

  </nav>

  <main>
    @RenderBody()
  </main>

  <!-- Overlay lives in the DOM (not commented out) so JS can find it -->
  <div class="overlay" id="overlay"></div>

  <script>
    const avatarBtn = document.getElementById('avatarBtn');
    const dropdown  = document.getElementById('dropdown');
    const overlay   = document.getElementById('overlay');

    function openMenu() {
      dropdown.classList.add('open');
      overlay.classList.add('active');
      avatarBtn.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      dropdown.classList.remove('open');
      overlay.classList.remove('active');
      avatarBtn.setAttribute('aria-expanded', 'false');
    }

    avatarBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      dropdown.classList.contains('open') ? closeMenu() : openMenu();
    });

    // Bug fix: overlay was commented out in HTML but JS still called .classList on it
    overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeMenu();
    });

    dropdown.querySelectorAll('a.dropdown-item').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });
  </script>

</body>
</html>

